{
  "name": "votevault-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:contract": "npm install --prefix contract",
    "compile:contract": "npm run compile --prefix contract",
    "install:frontend": "npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run install:contract && npm run compile:contract && npm run install:frontend && npm run build:frontend"
  }
}
